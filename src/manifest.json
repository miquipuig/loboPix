{
  "manifest_version": 3,
  "name": "loboTinify",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icons/loboQR-16.png",
    "32": "assets/icons/loboQR-32.png",
    "48": "assets/icons/loboQR-48.png",
    "128": "assets/icons/loboQR-128.png"
  },
  "action": {
    "default_title": "loboTinify",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/loboQR-16.png",
      "32": "assets/icons/loboQR-32.png",
      "48": "assets/icons/loboQR-48.png"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "favicon",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
